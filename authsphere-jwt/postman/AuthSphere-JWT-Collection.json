{
  "info": {
    "name": "AuthSphere JWT - API Collection",
    "_postman_id": "authsphere-jwt-final-001",
    "description": "Complete Postman collection for AuthSphere JWT project covering authentication, JWT validation, and role-based access control.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "user_token",
      "value": ""
    },
    {
      "key": "admin_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth APIs",
      "item": [
        {
          "name": "TC-01 Register Success",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "TC-05 Login Success (USER)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let res = pm.response.json();",
                  "let accessToken = (res.accessToken || '').trim();",
                  "pm.collectionVariables.unset('user_token');",
                  "pm.collectionVariables.set('user_token', accessToken);",
                  
                   "let refreshToken = (res.refreshToken|| '').trim();",
                  "pm.collectionVariables.unset('refresh_token');",
                  "pm.collectionVariables.set('refresh_token', refreshToken);",
                  
                  "console.log('USER ACCESS TOKEN:', accessToken);",
                  "console.log('USER REFRESH TOKEN:', refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-15 Login Success (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let res = pm.response.json();",
                  "let token = (res.accessToken || '').trim();",
                  "pm.collectionVariables.unset('admin_token');",
                  "pm.collectionVariables.set('admin_token', token);",
                  "console.log('ADMIN TOKEN:', token);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "JWT Authentication",
      "item": [
        {
          "name": "TC-08 Access Without Token",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/user/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "profile"]
            }
          }
        },
        {
          "name": "TC-09 Invalid Token",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer invalid_token" }
            ],
            "url": {
              "raw": "{{base_url}}/api/user/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "profile"]
            }
          }
        },
        {
          "name": "TC-11 User Profile (USER TOKEN)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/user/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Role-Based Authorization",
      "item": [
        {
          "name": "TC-13 USER → ADMIN API (Forbidden)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/dashboard",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "dashboard"]
            }
          }
        },
        {
          "name": "TC-17 ADMIN → ADMIN API",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/dashboard",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "dashboard"]
            }
          }
        },
        {
          "name": "TC-18 ADMIN → USER API",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/user/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Refresh Token Flow",
      "item": [
        {
          "name": "TC-REFRESH TOKEN - Generate New Access Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "text/plain" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{refresh_token}}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "refresh"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let res = pm.response.json();",
                  "pm.collectionVariables.set('user_token', res.accessToken);",
                  "console.log('ACCESS TOKEN REFRESHED SUCCESSFULLY');"
                ]
              }
            }
          ]
        },

        {
          "name": "TC-REFRESH TOKEN INVALID",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "text/plain" }
            ],
            "body": {
              "mode": "raw",
              "raw": "invalid_refresh_token"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "refresh"]
            }
          }
        }
      ]
    },
   {
	  "name": "Logout Flow",
	  "item": [
	    {
	      "name": "TC-LOGOUT USER",
	      "request": {
	        "method": "POST",
	        "header": [
	          { "key": "Content-Type", "value": "application/json" }
	        ],
	        "url": {
	          "raw": "{{base_url}}/api/auth/logout?username=user",
	          "host": ["{{base_url}}"],
	          "path": ["api", "auth", "logout"],
	          "query": [
	            {
	              "key": "username",
	              "value": "user"
	            }
	          ]
	        }
	      }
	    },
	    {
	      "name": "TC-USER REFRESH AFTER LOGOUT (SHOULD FAIL)",
	      "request": {
	        "method": "POST",
	        "header": [
	          { "key": "Content-Type", "value": "text/plain" }
	        ],
	        "body": {
	          "mode": "raw",
	          "raw": "{{refresh_token}}"
	        },
	        "url": {
	          "raw": "{{base_url}}/api/auth/refresh",
	          "host": ["{{base_url}}"],
	          "path": ["api", "auth", "refresh"]
	        }
	      }
	    },
	    {
	      "name": "TC-LOGOUT ADMIN",
	      "request": {
	        "method": "POST",
	        "header": [
	          { "key": "Content-Type", "value": "application/json" }
	        ],
	        "url": {
	          "raw": "{{base_url}}/api/auth/logout?username=admin",
	          "host": ["{{base_url}}"],
	          "path": ["api", "auth", "logout"],
	          "query": [
	            {
	              "key": "username",
	              "value": "admin"
	            }
	          ]
	        }
	      }
	    },
	    {
	      "name": "TC-ADMIN REFRESH AFTER LOGOUT (SHOULD FAIL)",
	      "request": {
	        "method": "POST",
	        "header": [
	          { "key": "Content-Type", "value": "text/plain" }
	        ],
	        "body": {
	          "mode": "raw",
	          "raw": "{{refresh_token}}"
	        },
	        "url": {
	          "raw": "{{base_url}}/api/auth/refresh",
	          "host": ["{{base_url}}"],
	          "path": ["api", "auth", "refresh"]
	        }
	      }
	    }
	  ]
	}  
  ]
}